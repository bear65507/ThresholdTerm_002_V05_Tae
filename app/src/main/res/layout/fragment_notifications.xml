<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.notifications.NotificationsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="도서관 찾기"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="초기 설정 또는 설정 탭에 저장된 지역을 기준으로 도서관 목록을 보여줍니다."
            android:textSize="15sp" />

        <TextView
            android:id="@+id/text_library_region"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#F2F7F5"
            android:padding="14dp"
            android:text="저장된 지역 정보를 불러오고 있습니다."
            android:textColor="#173B33"
            android:textSize="15sp" />

        <Button
            android:id="@+id/button_load_libraries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="내 주변 도서관 검색" />

        <TextView
            android:id="@+id/text_library_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:textSize="15sp" />

        <Button
            android:id="@+id/button_open_first_library_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="첫 번째 도서관 지도 열기" />

        <Button
            android:id="@+id/button_open_library_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="도서관 검색 Activity 열기" />

        <Button
            android:id="@+id/button_check_posture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="MediaPipe 샘플 집중 점수 확인" />

        <TextView
            android:id="@+id/text_focus_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:text="자세 감지를 시작하면 집중 점수가 표시됩니다."
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="MediaPipe 포즈 랜드마크와 스마트폰 감지 결과는 ml 패키지의 분석기로 연결할 수 있습니다."
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
